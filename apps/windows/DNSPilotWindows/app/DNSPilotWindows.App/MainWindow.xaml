<Window
    x:Class="DNSPilotWindows.App.MainWindow"
    x:Uid="MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="DNS Pilot">

    <Grid x:Name="RootGrid" Padding="24" RowSpacing="16" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideLayout" />
                <VisualState x:Name="CompactLayout" />
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Q" Modifiers="Control" Invoked="QuickBenchmarkAccelerator_Invoked" />
            <KeyboardAccelerator Key="Escape" Invoked="CancelBenchmarkAccelerator_Invoked" />
            <KeyboardAccelerator Key="S" Modifiers="Control" Invoked="SettingsAccelerator_Invoked" />
            <KeyboardAccelerator Key="H" Modifiers="Control" Invoked="HelpAccelerator_Invoked" />
        </Grid.KeyboardAccelerators>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock x:Uid="AppTitle" Text="DNS Pilot" FontSize="28" FontWeight="SemiBold" />
                <TextBlock x:Uid="AppSubtitle" Text="Windows Store-safe DNS benchmark shell" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <ComboBox x:Name="LanguageCombo" x:Uid="LanguageCombo" Width="88" SelectedIndex="0" SelectionChanged="Language_Changed" AutomationProperties.Name="Display language" AutomationProperties.AutomationId="LanguageSelector">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Uid="LanguageTooltip" Content="Choose English or Vietnamese. The app updates on next launch." />
                    </ToolTipService.ToolTip>
                    <ComboBoxItem Tag="en-US" Content="EN" />
                    <ComboBoxItem Tag="vi-VN" Content="VI" />
                </ComboBox>
                <Button x:Name="QuickBenchmarkButton" Click="QuickBenchmark_Click" AutomationProperties.Name="Quick Check" AutomationProperties.AutomationId="QuickCheckButton">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Uid="QuickBenchmarkTooltip" Content="Run the small DNS-only benchmark." />
                    </ToolTipService.ToolTip>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Play" />
                        <TextBlock x:Uid="QuickBenchmarkText" Text="Quick benchmark" />
                    </StackPanel>
                </Button>
                <Button x:Name="ValidateSystemDnsButton" Click="ValidateSystemDns_Click" AutomationProperties.Name="Validate current DNS" AutomationProperties.AutomationId="ValidateDnsButton">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Uid="ValidateDnsTooltip" Content="Benchmark the current Windows resolver path." />
                    </ToolTipService.ToolTip>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Refresh" />
                        <TextBlock x:Uid="ValidateDnsText" Text="Validate DNS" />
                    </StackPanel>
                </Button>
                <Button Click="OpenSettings_Click" AutomationProperties.Name="Open Windows Network Settings" AutomationProperties.AutomationId="OpenSettingsButton">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Uid="SettingsTooltip" Content="Open Windows Network settings without changing DNS." />
                    </ToolTipService.ToolTip>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Setting" />
                        <TextBlock x:Uid="SettingsText" Text="Settings" />
                    </StackPanel>
                </Button>
                <Button Click="ShowTutorial_Click" AutomationProperties.Name="Show setup help" AutomationProperties.AutomationId="HelpButton">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Uid="TutorialTooltip" Content="Show setup tutorial." />
                    </ToolTipService.ToolTip>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Help" />
                        <TextBlock x:Uid="TutorialText" Text="Help" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <NavigationView
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            PaneDisplayMode="Top"
            IsSettingsVisible="False"
            SelectionChanged="SectionNav_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="NavCheckDns" Content="Check DNS" Tag="CheckDns" Icon="Play" IsSelected="True" />
                <NavigationViewItem x:Uid="NavProfiles" Content="Profiles" Tag="Profiles" Icon="Edit" />
                <NavigationViewItem x:Uid="NavHistory" Content="History" Tag="History" Icon="Clock" />
            </NavigationView.MenuItems>
        </NavigationView>

        <InfoBar x:Name="RuntimeStatusBar" x:Uid="RuntimeStatusBar" Grid.Row="2" IsOpen="True" IsClosable="False" Severity="Informational" AutomationProperties.LiveSetting="Polite">
            <InfoBar.ActionButton>
                <Button x:Name="RetryRuntimeButton" Click="RetryRuntime_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Refresh" />
                        <TextBlock x:Uid="RuntimeRetryText" Text="Retry" />
                    </StackPanel>
                </Button>
            </InfoBar.ActionButton>
        </InfoBar>

        <ScrollViewer Grid.Row="3">
            <Grid x:Name="ContentGrid" ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ContentPrimaryColumn" Width="1.1*" />
                    <ColumnDefinition x:Name="ContentSecondaryColumn" Width="0.9*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="BenchmarkSection" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="14">
                        <TextBlock x:Uid="BenchmarkHeader" Text="Benchmark" FontSize="20" FontWeight="SemiBold" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ModeCombo" x:Uid="ModeCombo" Header="Mode" SelectedIndex="1" SelectionChanged="BenchmarkSelection_Changed">
                                <ToolTipService.ToolTip>
                                    <ToolTip x:Uid="ModeTooltip" Content="DNS only, DNS + TCP, or current/system DNS validation." />
                                </ToolTipService.ToolTip>
                                <ComboBoxItem x:Uid="ModeDnsOnly" Content="DNS only" />
                                <ComboBoxItem x:Uid="ModeDnsTcp" Content="DNS + TCP" />
                                <ComboBoxItem x:Uid="ModeSystemDns" Content="System DNS validation" />
                            </ComboBox>
                            <ComboBox x:Name="RecordFamilyCombo" x:Uid="RecordFamilyCombo" Grid.Column="1" Header="Record family" SelectedIndex="0" SelectionChanged="BenchmarkSelection_Changed">
                                <ToolTipService.ToolTip>
                                    <ToolTip x:Uid="RecordFamilyTooltip" Content="A returns IPv4 answers. AAAA returns IPv6 answers. Use A only when IPv6 is weak." />
                                </ToolTipService.ToolTip>
                                <ComboBoxItem x:Uid="RecordFamilyBoth" Content="A + AAAA" />
                                <ComboBoxItem x:Uid="RecordFamilyIpv4" Content="A only" />
                                <ComboBoxItem x:Uid="RecordFamilyIpv6" Content="AAAA only" />
                            </ComboBox>
                            <ComboBox x:Name="ResolverFamilyCombo" x:Uid="ResolverFamilyCombo" Grid.Column="2" Header="Resolver address" SelectedIndex="0" SelectionChanged="BenchmarkSelection_Changed">
                                <ToolTipService.ToolTip>
                                    <ToolTip x:Uid="ResolverFamilyTooltip" Content="Choose Auto, IPv4 DNS servers only, or IPv6 DNS servers only." />
                                </ToolTipService.ToolTip>
                                <ComboBoxItem x:Uid="ResolverFamilyAuto" Content="Auto" />
                                <ComboBoxItem x:Uid="ResolverFamilyIpv4" Content="IPv4" />
                                <ComboBoxItem x:Uid="ResolverFamilyIpv6" Content="IPv6" />
                            </ComboBox>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <NumberBox x:Name="AttemptsBox" x:Uid="AttemptsBox" Header="Attempts" Value="2" Minimum="1" ValueChanged="BenchmarkNumber_ValueChanged" />
                            <NumberBox x:Name="DnsTimeoutBox" x:Uid="DnsTimeoutBox" Grid.Column="1" Header="DNS timeout ms" Value="800" Minimum="1" ValueChanged="BenchmarkNumber_ValueChanged" />
                            <NumberBox x:Name="TcpTimeoutBox" x:Uid="TcpTimeoutBox" Grid.Column="2" Header="TCP timeout ms" Value="1000" Minimum="1" ValueChanged="BenchmarkNumber_ValueChanged" />
                            <NumberBox x:Name="TcpTargetsBox" x:Uid="TcpTargetsBox" Grid.Column="3" Header="TCP targets/domain" Value="4" Minimum="1" ValueChanged="BenchmarkNumber_ValueChanged" />
                        </Grid>

                        <ListView x:Name="BenchmarkProfilesList" x:Uid="BenchmarkProfilesList" Header="Resolver profiles" SelectionMode="Multiple" MaxHeight="140" SelectionChanged="BenchmarkProfiles_SelectionChanged">
                            <ToolTipService.ToolTip>
                                <ToolTip x:Uid="BenchmarkProfilesTooltip" Content="Select plain DNS profiles to include in DNS-only or DNS + TCP benchmarks." />
                            </ToolTipService.ToolTip>
                        </ListView>

                        <ComboBox x:Name="SuiteCombo" x:Uid="SuiteCombo" Header="Domain suite" SelectionChanged="BenchmarkSelection_Changed">
                            <ToolTipService.ToolTip>
                                <ToolTip x:Uid="SuiteTooltip" Content="Choose a saved domain suite for benchmark targets." />
                            </ToolTipService.ToolTip>
                        </ComboBox>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="DefaultSuiteQuickPickButton" x:Uid="DefaultSuiteQuickPickButton" Click="DefaultSuiteQuickPick_Click" Visibility="Collapsed" AutomationProperties.Name="Choose default domain suite">
                                <TextBlock x:Uid="DefaultSuiteQuickPickText" Text="Default" />
                            </Button>
                            <Button x:Name="VietnamSuiteQuickPickButton" x:Uid="VietnamSuiteQuickPickButton" Click="VietnamSuiteQuickPick_Click" Visibility="Collapsed" AutomationProperties.Name="Choose Vietnam domain suite">
                                <TextBlock x:Uid="VietnamSuiteQuickPickText" Text="Vietnam" />
                            </Button>
                        </StackPanel>
                        <TextBlock x:Name="SuiteLimitationNoticeText" x:Uid="GamingSuiteNotice" Text="Game checks use DNS + TCP. They are not ICMP ping or in-match UDP latency." TextWrapping="Wrap" Visibility="Collapsed" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <TextBlock x:Uid="CommandPreviewHeader" Text="Command preview" FontWeight="SemiBold" />
                        <TextBox x:Name="CommandPreviewBox" IsReadOnly="True" TextWrapping="Wrap" MinHeight="76" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="RunBenchmarkButton" Click="RunBenchmark_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Play" />
                                    <TextBlock x:Uid="RunBenchmarkText" Text="Run benchmark" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="CancelBenchmarkButton" Click="CancelBenchmark_Click" Visibility="Collapsed" AutomationProperties.Name="Cancel benchmark" AutomationProperties.AutomationId="CancelBenchmarkButton">
                                <ToolTipService.ToolTip>
                                    <ToolTip x:Uid="CancelBenchmarkTooltip" Content="Stop the running benchmark." />
                                </ToolTipService.ToolTip>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Cancel" />
                                    <TextBlock x:Uid="CancelBenchmarkText" Text="Cancel" />
                                </StackPanel>
                            </Button>
                            <Button Click="CopyCommand_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Copy" />
                                    <TextBlock x:Uid="CopyCommandText" Text="Copy command" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="ProcessSection" Grid.Column="1" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="14">
                        <TextBlock x:Uid="ProcessHeader" Text="Process" FontSize="20" FontWeight="SemiBold" />
                        <ListView x:Name="StepsList" x:Uid="StepsList" Header="Steps" MaxHeight="220" />
                        <ListView x:Name="ResolversList" x:Uid="ResolversList" Header="Resolvers" MaxHeight="220" />
                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="RecommendationReportHeader" Text="Recommendation" FontWeight="SemiBold" />
                            <TextBlock x:Name="RecommendationSummaryText" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="RecommendationLineText" TextWrapping="Wrap" FontSize="16" FontWeight="SemiBold" />
                            <ListView x:Name="RecommendationResolversList" x:Uid="RecommendationResolversList" Header="Resolver metrics" MaxHeight="140" />
                            <ListView x:Name="RecommendationNotesList" x:Uid="RecommendationNotesList" Header="Notes" MaxHeight="120" />
                            <Expander x:Name="AdvancedDiagnosticsExpander" x:Uid="AdvancedDiagnosticsExpander" Header="Advanced diagnostics">
                                <StackPanel Spacing="8">
                                    <ListView x:Name="CapabilityRowsList" x:Uid="CapabilityRowsList" Header="Capability status" MaxHeight="140" />
                                    <TextBox x:Name="DiagnosticsBox" x:Uid="DiagnosticsBox" Header="Report" IsReadOnly="True" TextWrapping="Wrap" MinHeight="160" />
                                    <Button Click="CopyDiagnostics_Click" AutomationProperties.Name="Copy technical report" AutomationProperties.AutomationId="CopyDiagnosticsButton">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <SymbolIcon Symbol="Copy" />
                                            <TextBlock x:Uid="CopyDiagnosticsText" Text="Copy report" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="ApplySection" Grid.Row="1" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="14">
                        <TextBlock x:Uid="ApplyHeader" Text="Apply guidance" FontSize="20" FontWeight="SemiBold" />
                        <TextBox x:Name="DnsServersBox" x:Uid="DnsServersBox" Header="DNS servers" IsReadOnly="True" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="ApplyInSettingsButton" Click="ApplyInWindowsSettings_Click" AutomationProperties.Name="Apply in Windows Settings" AutomationProperties.AutomationId="ApplyInSettingsButton">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Setting" />
                                    <TextBlock x:Uid="ApplyInSettingsText" Text="Apply in Windows Settings" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="CopyDnsButton" Click="CopyDnsServers_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Copy" />
                                    <TextBlock x:Uid="CopyDnsText" Text="Copy DNS" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="RetestSystemDnsButton" Click="RetestSystemDns_Click" Visibility="Collapsed" AutomationProperties.Name="Retest System DNS" AutomationProperties.AutomationId="RetestSystemDnsButton">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Refresh" />
                                    <TextBlock x:Uid="RetestSystemDnsText" Text="Retest System DNS" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="CopyChecklistButton" Click="CopyChecklist_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="List" />
                                    <TextBlock x:Uid="CopyChecklistText" Text="Copy checklist" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <TextBox x:Name="ChecklistBox" x:Uid="ChecklistBox" Header="Checklist" IsReadOnly="True" TextWrapping="Wrap" MinHeight="120" />
                        <Expander x:Name="NetworkSignalsExpander" x:Uid="NetworkSignalsExpander" Header="Network safeguards">
                            <StackPanel Spacing="6">
                                <CheckBox x:Name="VpnActiveCheckBox" x:Uid="VpnActiveCheckBox" Content="VPN active" Checked="NetworkSignal_Changed" Unchecked="NetworkSignal_Changed" />
                                <CheckBox x:Name="ManagedDnsCheckBox" x:Uid="ManagedDnsCheckBox" Content="Managed DNS profile" Checked="NetworkSignal_Changed" Unchecked="NetworkSignal_Changed" />
                                <CheckBox x:Name="CorporateDnsCheckBox" x:Uid="CorporateDnsCheckBox" Content="Corporate DNS" Checked="NetworkSignal_Changed" Unchecked="NetworkSignal_Changed" />
                                <CheckBox x:Name="CaptivePortalCheckBox" x:Uid="CaptivePortalCheckBox" Content="Captive portal" Checked="NetworkSignal_Changed" Unchecked="NetworkSignal_Changed" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <Grid x:Name="ProfilesSection" Grid.Row="1" Grid.Column="1" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border x:Name="ProfilesSection" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <StackPanel Spacing="12">
                            <TextBlock x:Uid="ProfilesHeader" Text="Custom DNS profiles" FontSize="20" FontWeight="SemiBold" />
                            <ListView x:Name="ProfilesList" x:Uid="ProfilesList" Header="Saved profiles" MaxHeight="160" SelectionChanged="ProfilesList_SelectionChanged" />
                            <TextBox x:Name="ProfileNameBox" x:Uid="ProfileNameBox" Header="Name" Text="Cloudflare Lab" />
                            <TextBox x:Name="ProfileIdBox" x:Uid="ProfileIdBox" Header="Profile ID for update/delete" Text="cloudflare-lab" />
                            <TextBox x:Name="Ipv4Box" x:Uid="Ipv4Box" Header="IPv4 servers" Text="1.1.1.1, 1.0.0.1">
                                <ToolTipService.ToolTip>
                                    <ToolTip x:Uid="Ipv4Tooltip" Content="Plain IPv4 DNS server addresses." />
                                </ToolTipService.ToolTip>
                            </TextBox>
                            <TextBox x:Name="Ipv6Box" x:Uid="Ipv6Box" Header="IPv6 servers" Text="2606:4700:4700::1111">
                                <ToolTipService.ToolTip>
                                    <ToolTip x:Uid="Ipv6Tooltip" Content="Plain IPv6 DNS server addresses." />
                                </ToolTipService.ToolTip>
                            </TextBox>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="PreviewProfileSave_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="PreviewLink" />
                                        <TextBlock x:Uid="PreviewProfileText" Text="Preview" />
                                    </StackPanel>
                                </Button>
                                <Button Click="SaveProfile_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Save" />
                                        <TextBlock x:Uid="AddProfileText" Text="Add" />
                                    </StackPanel>
                                </Button>
                                <Button Click="UpdateProfile_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Edit" />
                                        <TextBlock x:Uid="UpdateProfileText" Text="Update" />
                                    </StackPanel>
                                </Button>
                                <Button Click="DeleteProfile_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Delete" />
                                        <TextBlock x:Uid="DeleteProfileText" Text="Delete" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="SuitesSection" Grid.Row="1" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <StackPanel Spacing="12">
                            <TextBlock x:Uid="SuitesHeader" Text="Domain suites" FontSize="20" FontWeight="SemiBold" />
                            <ListView x:Name="SuitesList" x:Uid="SuitesList" Header="Saved suites" MaxHeight="140" SelectionChanged="SuitesList_SelectionChanged" />
                            <TextBox x:Name="SuiteNameBox" x:Uid="SuiteNameBox" Header="Name" Text="Azure Lab" />
                            <TextBox x:Name="SuiteIdBox" x:Uid="SuiteIdBox" Header="Suite ID for update/delete" Text="custom-azure-lab" />
                            <TextBox x:Name="SuiteDomainsBox" x:Uid="SuiteDomainsBox" Header="Domains" Text="portal.azure.com, login.microsoftonline.com" TextWrapping="Wrap">
                                <ToolTipService.ToolTip>
                                    <ToolTip x:Uid="SuiteDomainsTooltip" Content="Domains to benchmark, separated by commas, spaces, or new lines." />
                                </ToolTipService.ToolTip>
                            </TextBox>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="PreviewSuiteSave_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="PreviewLink" />
                                        <TextBlock x:Uid="PreviewSuiteText" Text="Preview" />
                                    </StackPanel>
                                </Button>
                                <Button Click="SaveSuite_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Save" />
                                        <TextBlock x:Uid="AddSuiteText" Text="Add" />
                                    </StackPanel>
                                </Button>
                                <Button Click="UpdateSuite_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Edit" />
                                        <TextBlock x:Uid="UpdateSuiteText" Text="Update" />
                                    </StackPanel>
                                </Button>
                                <Button Click="DeleteSuite_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Delete" />
                                        <TextBlock x:Uid="DeleteSuiteText" Text="Delete" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </Grid>

                <Border x:Name="HistorySection" Grid.Row="1" Grid.Column="1" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Visibility="Collapsed">
                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="HistoryHeader" Text="History" FontSize="20" FontWeight="SemiBold" />
                        <ListView x:Name="HistoryList" x:Uid="HistoryList" Header="Saved checks" MaxHeight="320" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="RefreshStorageButton" Click="RefreshStorage_Click" AutomationProperties.Name="Refresh history">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Refresh" />
                                    <TextBlock x:Uid="RefreshStorageText" Text="Refresh" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="ClearHistoryButton" Click="ClearHistory_Click" AutomationProperties.Name="Clear history">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Delete" />
                                    <TextBlock x:Uid="ClearHistoryText" Text="Clear history" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="DeleteHistoryButton" Click="DeleteHistory_Click" AutomationProperties.Name="Delete selected history">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Remove" />
                                    <TextBlock x:Uid="DeleteSelectedHistoryText" Text="Delete selected" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
