{
  "expo": {
    "name": "DNSPilot Mobile",
    "slug": "dnspilot-mobile",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "dnspilot",
    "userInterfaceStyle": "automatic",
    "locales": {
      "en": "./languages/en.json",
      "vi": "./languages/vi.json"
    },
    "ios": {
      "bundleIdentifier": "com.dnspilot.mobile",
      "buildNumber": "1",
      "supportsTablet": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "NSLocalNetworkUsageDescription": "DNSPilot uses the local network only to connect to your selected DNSPilot bridge or LAN diagnostic endpoint during testing."
      }
    },
    "android": {
      "package": "com.dnspilot.mobile",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-dev-client",
        {
          "launchMode": "launcher",
          "toolsButton": true,
          "skipOnboarding": false,
          "showMenuAtLaunch": true
        }
      ],
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "en",
              "vi"
            ],
            "android": [
              "en",
              "vi"
            ]
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "extra": {
      "dnspilotBridgeUrl": "http://localhost:8787",
      "supportedLocales": [
        "en",
        "vi"
      ],
      "supportsRTL": false
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
