{
  "name": "dnspilot-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "expo": "^57.0.0",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.2",
    "expo-dev-client": "~57.0.4",
    "expo-font": "~57.0.0",
    "expo-intent-launcher": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-localization": "~57.0.0",
    "expo-router": "~57.0.2",
    "expo-splash-screen": "~57.0.1",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "bridge": "node server/dev-server.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start:dev-client": "expo start --dev-client --lan --port 8082",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "node --test server/*.test.mjs src/view-models/*.test.mjs plugins/*.test.mjs",
    "postinstall": "patch-package",
    "verify": "npm test && npm run typecheck && npx expo config --type public && npx expo export --platform web && npx expo install --check && npm audit --omit=dev --audit-level=high"
  },
  "private": true
}
