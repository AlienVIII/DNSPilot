{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote",
    "requireCommit": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium",
        "image": "sdk-57"
      },
      "android": {
        "buildType": "app-bundle",
        "image": "sdk-57"
      }
    },
    "production-ios-dns": {
      "autoIncrement": true,
      "env": {
        "DNSPILOT_IOS_DNS_SETTINGS": "1"
      },
      "ios": {
        "resourceClass": "m-medium",
        "image": "sdk-57"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
